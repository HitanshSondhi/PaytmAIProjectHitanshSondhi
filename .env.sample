# ============================================================
# Voice Ledger Frontend — Environment Variables Sample
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
#
# IMPORTANT: Never commit your actual .env file to version control.
# ============================================================

# ----------------------------------------------------------
# API Configuration
# ----------------------------------------------------------
# In development: Leave empty to use Vite's proxy (recommended)
# In production: Set to your deployed backend URL (e.g. https://api.yourapp.com)
VITE_API_URL=

# ----------------------------------------------------------
# ElevenLabs — Text-to-Speech
# ----------------------------------------------------------
# Obtain your API key from: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ----------------------------------------------------------
# ElevenLabs — Voice ID / Secondary Key (optional)
# ----------------------------------------------------------
# Obtain your API key from: https://elevenlabs.io/app/settings/api-keys
VITE_SARVAM_API_KEY=your_elevenlabs_secondary_key_here

# ----------------------------------------------------------
# Stitch MCP — Design System
# ----------------------------------------------------------
# Obtain your API key from your Stitch dashboard
STITCH_API_KEY=your_stitch_api_key_here
